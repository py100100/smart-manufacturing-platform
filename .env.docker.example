APP_ENV=docker
DEBUG=false

# Local Docker-only placeholders. Replace them in .env.docker before real deployment.
MYSQL_ROOT_PASSWORD=change_me_for_local_docker
MYSQL_DB=smart_manufacturing
BACKEND_PORT=8000
FRONTEND_PORT=3001

