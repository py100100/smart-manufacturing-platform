APP_ENV=docker
DEBUG=false

# Local Docker-only placeholders. Replace them in .env.docker before real deployment.
MYSQL_ROOT_PASSWORD=change_me_for_local_docker
MYSQL_DB=smart_manufacturing
BACKEND_PORT=8000
FRONTEND_PORT=3001
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

DOCKER_DEEPSEEK_API_KEY=
DOCKER_DEEPSEEK_BASE_URL=https://api.deepseek.com
DOCKER_DEEPSEEK_MODEL=deepseek-v4-flash
MCP_ENABLED=false
MCP_SERVER_URL=
MCP_TOOL_NAME=
MCP_AUTH_TOKEN=
MCP_TIMEOUT_SECONDS=5
NEO4J_ENABLED=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_for_local_neo4j
